{
  "uid": "claude-code-metrics",
  "title": "Claude Code Metrics",
  "tags": ["claude", "metrics"],
  "schemaVersion": 39,
  "editable": true,
  "style": "dark",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
        "query": "SHOW TAG VALUES FROM \"claude_session\" WITH KEY = \"host\"",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
        "query": "SHOW TAG VALUES FROM \"claude_session\" WITH KEY = \"model\"",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      },
      {
        "name": "project",
        "type": "query",
        "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
        "query": "SHOW TAG VALUES FROM \"claude_session\" WITH KEY = \"project\"",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      },
      {
        "name": "worktree",
        "type": "query",
        "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
        "query": "SHOW TAG VALUES FROM \"claude_session\" WITH KEY = \"worktree\"",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      },
      {
        "name": "session",
        "type": "query",
        "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
        "query": "SHOW TAG VALUES FROM \"claude_session\" WITH KEY = \"session\"",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      }
    ]
  },
  "panels": [
    {
      "id": 12,
      "title": "Total Cost",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
          "rawQuery": true,
          "query": "SELECT sum(\"max_cost\") AS \"total_cost\" FROM (SELECT max(\"cost\") AS \"max_cost\" FROM \"claude_session\" WHERE $timeFilter AND \"host\" =~ /^$host$/ AND \"model\" =~ /^$model$/ AND \"project\" =~ /^$project$/ AND \"worktree\" =~ /^$worktree$/ AND \"session\" =~ /^$session$/ GROUP BY \"session\", \"host\", \"model\", \"project\", \"worktree\")",
          "resultFormat": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 13,
      "title": "Total Tokens",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
          "rawQuery": true,
          "query": "SELECT sum(\"max_in\") + sum(\"max_crd\") + sum(\"max_ccr\") AS \"total_tokens\" FROM (SELECT max(\"in_tok\") AS \"max_in\", max(\"cache_rd\") AS \"max_crd\", max(\"cache_cr\") AS \"max_ccr\" FROM \"claude_session\" WHERE $timeFilter AND \"host\" =~ /^$host$/ AND \"model\" =~ /^$model$/ AND \"project\" =~ /^$project$/ AND \"worktree\" =~ /^$worktree$/ AND \"session\" =~ /^$session$/ GROUP BY \"session\", \"host\", \"model\", \"project\", \"worktree\")",
          "resultFormat": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 14,
      "title": "Total Lines Changed",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
          "rawQuery": true,
          "query": "SELECT sum(\"max_add\") + sum(\"max_rm\") AS \"total_lines\" FROM (SELECT max(\"lines_add\") AS \"max_add\", max(\"lines_rm\") AS \"max_rm\" FROM \"claude_session\" WHERE $timeFilter AND \"host\" =~ /^$host$/ AND \"model\" =~ /^$model$/ AND \"project\" =~ /^$project$/ AND \"worktree\" =~ /^$worktree$/ AND \"session\" =~ /^$session$/ GROUP BY \"session\", \"host\", \"model\", \"project\", \"worktree\")",
          "resultFormat": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "orange", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 1,
      "title": "Session Cost",
      "type": "stat",
      "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 5},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "claude-influxdb"},
          "measurement": "claude_session",
          "select": [[
            {"type": "field", "params": ["cost"]},
            {"type": "last", "params": []}
          ]],
          "groupBy": [
            {"type": "time", "params": ["$__interval"]},
            {"type": "fill", "params": ["null"]}
          ],
          "tags": [
            {"key": "host", "operator": "=~", "value": "/^$host$/"},
            {"condition": "AND", "key": "model", "operator": "=~", "value": "/^$model$/"},
            {"condition": "AND", "key": "project", "operator": "=~", "value": "/^$project$/"},
            {"condition": "AND", "key": "worktree", "operator": "=~", "value": "/^$worktree$/"},
            {"condition": "AND", "key": "session", "operator": "=~", "value": "/^$session$/"}
          ],
          "alias": "Cost"
